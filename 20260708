<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>COD-BOD 상관관계 분석 대시보드</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.4.1/papaparse.min.js"></script>
<style>
  :root{
    --bg:#0f1419; --panel:#161d27; --panel2:#1c2531; --border:#2a3441;
    --text:#e8edf2; --sub:#8a97a8; --accent:#4fd1c5; --accent2:#f6ad55;
    --danger:#fc8181; --good:#68d391;
  }
  *{box-sizing:border-box;}
  body{
    margin:0; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Pretendard,sans-serif;
    background:var(--bg); color:var(--text); padding:24px;
  }
  .wrap{max-width:1180px; margin:0 auto;}
  h1{font-size:22px; margin:0 0 4px;}
  .sub{color:var(--sub); font-size:13px; margin-bottom:20px;}
  .tabs{display:flex; gap:8px; margin-bottom:16px;}
  .tab{
    padding:9px 16px; border-radius:8px; background:var(--panel); border:1px solid var(--border);
    cursor:pointer; font-size:13px; color:var(--sub);
  }
  .tab.active{background:var(--accent); color:#08302c; border-color:var(--accent); font-weight:600;}
  .card{
    background:var(--panel); border:1px solid var(--border); border-radius:12px;
    padding:20px; margin-bottom:16px;
  }
  .card h2{font-size:14px; margin:0 0 14px; color:var(--sub); font-weight:600; letter-spacing:0.3px;}
  .row{display:flex; gap:12px; flex-wrap:wrap; align-items:flex-end;}
  .field{display:flex; flex-direction:column; gap:6px; flex:1; min-width:150px;}
  .field label{font-size:12px; color:var(--sub);}
  input, select{
    background:var(--panel2); border:1px solid var(--border); color:var(--text);
    padding:9px 10px; border-radius:7px; font-size:13px; outline:none;
  }
  input:focus, select:focus{border-color:var(--accent);}
  button{
    background:var(--accent); color:#08302c; border:none; padding:10px 18px;
    border-radius:7px; font-size:13px; font-weight:700; cursor:pointer; white-space:nowrap;
  }
